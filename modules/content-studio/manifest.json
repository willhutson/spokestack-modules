{
  "id": "content-studio",
  "moduleType": "CONTENT_STUDIO",
  "name": "Content Studio",
  "version": "1.0.0",
  "description": "LMTD's full creative pipeline — DAM, video, moodboards, presentations, docs, and content approvals",
  "category": "custom",
  "minTier": "BUSINESS",
  "price": null,
  "agentDefinition": {
    "path": "src/agent/content-agent.ts",
    "name": "content_studio_agent"
  },
  "tools": [
    {
      "name": "create_brief",
      "description": "Create a new creative brief",
      "method": "POST",
      "path": "/api/v1/briefs",
      "parameters": {
        "title": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        }
      }
    },
    {
      "name": "list_briefs",
      "description": "List all briefs, optionally filtered by status",
      "method": "GET",
      "path": "/api/v1/briefs",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_clients",
      "description": "List all clients in the workspace",
      "method": "GET",
      "path": "/api/v1/clients",
      "parameters": {}
    },
    {
      "name": "read_context",
      "description": "Read organizational context — team patterns, client info, preferences, insights",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "category": {
          "type": "string",
          "in": "query"
        },
        "entryType": {
          "type": "string",
          "in": "query",
          "enum": [
            "ENTITY",
            "PATTERN",
            "PREFERENCE",
            "INSIGHT"
          ]
        }
      }
    }
  ],
  "surfaces": [
    {
      "id": "content-home",
      "type": "full-page",
      "route": "/content",
      "requiredTools": [
        "listAssets",
        "listMoodboards",
        "listVideoProjects",
        "listDecks",
        "listDocuments",
        "listPendingReviews"
      ]
    },
    {
      "id": "content-assets",
      "type": "full-page",
      "route": "/content/assets",
      "requiredTools": [
        "uploadAsset",
        "listAssets",
        "searchAssets",
        "createFolder",
        "listFolders"
      ]
    },
    {
      "id": "content-video",
      "type": "full-page",
      "route": "/content/video",
      "requiredTools": [
        "createVideoProject",
        "listVideoProjects",
        "getVideoProject",
        "writeScript",
        "buildStoryboard"
      ]
    },
    {
      "id": "content-moodboards",
      "type": "full-page",
      "route": "/content/moodboards",
      "requiredTools": [
        "createMoodboard",
        "listMoodboards",
        "addToMoodboard",
        "listMoodboardItems"
      ]
    },
    {
      "id": "content-docs",
      "type": "full-page",
      "route": "/content/docs",
      "requiredTools": [
        "createDocument",
        "listDocuments",
        "getDocument",
        "searchKnowledge"
      ]
    },
    {
      "id": "content-approvals",
      "type": "full-page",
      "route": "/content/approvals",
      "requiredTools": [
        "submitForApproval",
        "reviewContent",
        "listPendingReviews",
        "trackContentStatus"
      ]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  },
  "contextSchema": {
    "categoryPrefix": "content",
    "entityTypes": [
      {
        "category": "content.brief",
        "keyFormat": "{briefId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": [
                "draft",
                "review",
                "approved",
                "published"
              ]
            },
            "assigneeId": {
              "type": "string"
            },
            "dueDate": {
              "type": "string",
              "format": "date"
            }
          },
          "required": [
            "title",
            "status"
          ]
        },
        "relatedCategories": [
          "content.campaign"
        ]
      },
      {
        "category": "content.campaign",
        "keyFormat": "{campaignId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "channel": {
              "type": "string"
            },
            "startDate": {
              "type": "string",
              "format": "date"
            },
            "budget": {
              "type": "number"
            }
          },
          "required": [
            "name"
          ]
        },
        "relatedCategories": [
          "content.brief",
          "finance.budget"
        ]
      }
    ],
    "patternTypes": [
      "approval_cycle_delay",
      "content_volume_spike"
    ]
  },
  "canvasConfig": {
    "nodeType": "ASSET",
    "color": "#8B5CF6",
    "icon": "image",
    "entityLabel": "Asset",
    "relationships": [
      {
        "sourceField": "briefId",
        "targetModule": "BRIEFS",
        "targetEntity": "brief",
        "label": "from brief",
        "edgeStyle": "solid"
      },
      {
        "sourceField": "projectId",
        "targetModule": "PROJECTS",
        "targetEntity": "project",
        "label": "part of",
        "edgeStyle": "dashed"
      }
    ]
  },
  "type": "CONTENT_STUDIO",
  "slug": "content-studio",
  "agentType": "content_creator",
  "pricing": {
    "type": "subscription",
    "monthlyPriceCents": 1500
  },
  "author": {
    "name": "SpokeStack",
    "url": "https://spokestack.dev"
  }
}
