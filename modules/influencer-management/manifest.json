{
  "id": "influencer-management",
  "moduleType": "INFLUENCER_MGMT",
  "name": "Influencer Management",
  "version": "1.0.0",
  "description": "Manage influencer relationships, campaigns, contracts, deliverables, and ROI tracking for PR and marketing agencies.",
  "category": "marketing",
  "minTier": "PRO",
  "agentDefinition": {
    "path": "src/agent/influencer-management-agent.ts",
    "name": "influencer-management-agent"
  },
  "tools": [
    {
      "name": "add_influencer",
      "description": "Add an influencer to the database",
      "method": "POST",
      "path": "/api/v1/context",
      "parameters": {
        "key": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "object",
          "required": true,
          "description": "{ name, handle, platform, followers, engagementRate, niche, location, rateCard, pastCampaigns[] }"
        }
      },
      "fixedBodyMerge": {
        "entryType": "ENTITY",
        "category": "influencer"
      }
    },
    {
      "name": "search_influencers",
      "description": "Search the influencer database",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "category": {
          "type": "string",
          "default": "influencer",
          "in": "query"
        }
      }
    },
    {
      "name": "create_influencer_campaign",
      "description": "Create an influencer campaign (as a Project)",
      "method": "POST",
      "path": "/api/v1/projects",
      "parameters": {
        "name": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string"
        }
      }
    },
    {
      "name": "create_deliverable",
      "description": "Create a deliverable task for an influencer",
      "method": "POST",
      "path": "/api/v1/tasks",
      "parameters": {
        "title": {
          "type": "string",
          "required": true
        },
        "description": {
          "type": "string"
        },
        "dueDate": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "default": "HIGH"
        }
      }
    },
    {
      "name": "create_influencer_contract",
      "description": "Create a contract/payment order for an influencer",
      "method": "POST",
      "path": "/api/v1/orders",
      "parameters": {
        "clientId": {
          "type": "string",
          "required": true,
          "description": "The brand client paying for this"
        },
        "items": {
          "type": "array",
          "required": true,
          "description": "[{description, quantity, unitPriceCents}]"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    {
      "name": "list_campaigns",
      "description": "List influencer campaigns",
      "method": "GET",
      "path": "/api/v1/projects",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_clients",
      "description": "List all clients in the workspace",
      "method": "GET",
      "path": "/api/v1/clients",
      "parameters": {}
    },
    {
      "name": "read_context",
      "description": "Read organizational context — team patterns, client info, preferences, insights",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "category": {
          "type": "string",
          "in": "query"
        },
        "entryType": {
          "type": "string",
          "in": "query",
          "enum": [
            "ENTITY",
            "PATTERN",
            "PREFERENCE",
            "INSIGHT"
          ]
        }
      }
    }
  ],
  "surfaces": [
    {
      "id": "influencer-management-dashboard",
      "type": "dashboard",
      "requiredTools": [
        "searchInfluencers",
        "calculateROI"
      ]
    },
    {
      "id": "influencer-management-home",
      "type": "full-page",
      "route": "/influencer-management",
      "requiredTools": [
        "searchInfluencers",
        "addInfluencer",
        "createInfluencerCampaign"
      ]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  },
  "type": "INFLUENCER_MGMT",
  "slug": "influencer-management",
  "agentType": "influencer_manager",
  "pricing": {
    "type": "subscription",
    "monthlyPriceCents": 2000
  },
  "author": {
    "name": "SpokeStack",
    "url": "https://spokestack.dev"
  },
  "contextCategories": [
    "influencer",
    "campaign"
  ]
}
