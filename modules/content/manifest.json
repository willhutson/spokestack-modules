    { "id": "content-assets", "type": "full-page", "route": "/content/assets", "requiredTools": ["listAssets", "uploadAsset", "searchAssets"] },
    { "id": "content-video", "type": "full-page", "route": "/content/video", "requiredTools": ["listVideoProjects", "createVideoProject"] },
