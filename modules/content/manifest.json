    "writeScript",
    "getScript",
    "buildStoryboard",
    "addStoryboardFrame",
    "listStoryboardFrames",
    "trackVideoStatus",
    "createDeck",
    "listDecks",
    "getDeck",
    "addSlide",
    "reorderSlides",
    "deleteSlide",
    "listTemplates",
    "createTemplate",
    "exportDeck",
    "syncDeckToGoogleSlides",
    "createDocument",
    "listDocuments",
    "getDocument",
