{
  "id": "analytics",
  "moduleType": "ANALYTICS",
  "name": "Analytics",
  "version": "1.0.0",
  "description": "Dashboards, widgets, and metric definitions for agency performance tracking and reporting.",
  "category": "analytics",
  "minTier": "PRO",
  "price": 1200,
  "agentDefinition": {
    "path": "src/agent/analytics-agent.ts",
    "name": "analytics-agent"
  },
  "tools": [
    {
      "name": "list_tasks",
      "description": "List tasks with optional status filter",
      "method": "GET",
      "path": "/api/v1/tasks",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        },
        "assigneeId": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_projects",
      "description": "List all projects, optionally filtered by status",
      "method": "GET",
      "path": "/api/v1/projects",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_briefs",
      "description": "List all briefs, optionally filtered by status",
      "method": "GET",
      "path": "/api/v1/briefs",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_orders",
      "description": "List all orders",
      "method": "GET",
      "path": "/api/v1/orders",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_clients",
      "description": "List all clients in the workspace",
      "method": "GET",
      "path": "/api/v1/clients",
      "parameters": {}
    },
    {
      "name": "list_invoices",
      "description": "List all invoices (via orders with invoice data)",
      "method": "GET",
      "path": "/api/v1/orders",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "read_context",
      "description": "Read organizational context — team patterns, client info, preferences, insights",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "category": {
          "type": "string",
          "in": "query"
        },
        "entryType": {
          "type": "string",
          "in": "query",
          "enum": [
            "ENTITY",
            "PATTERN",
            "PREFERENCE",
            "INSIGHT"
          ]
        }
      }
    },
    {
      "name": "get_recent_activity",
      "description": "Get recent activity across all entities in the workspace",
      "method": "GET",
      "path": "/api/v1/activity",
      "parameters": {
        "limit": {
          "type": "integer",
          "in": "query",
          "default": 20
        }
      }
    },
    {
      "name": "list_team_members",
      "description": "List all team members in the workspace",
      "method": "GET",
      "path": "/api/v1/team",
      "parameters": {}
    },
    {
      "name": "search_workspace",
      "description": "Search across tasks, projects, briefs, clients, and orders via context graph",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "search": {
          "type": "string",
          "required": true,
          "in": "query",
          "description": "Search query"
        }
      }
    }
  ],
  "surfaces": [
    {
      "id": "analytics-home",
      "type": "full-page",
      "route": "/analytics",
      "requiredTools": [
        "listDashboards",
        "listMetrics"
      ]
    },
    {
      "id": "analytics-dashboards",
      "type": "full-page",
      "route": "/analytics/dashboards",
      "requiredTools": [
        "listDashboards",
        "getDashboard",
        "createDashboard"
      ]
    },
    {
      "id": "analytics-metrics",
      "type": "full-page",
      "route": "/analytics/metrics",
      "requiredTools": [
        "listMetrics",
        "defineMetric",
        "snapshotMetrics"
      ]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  },
  "canvasConfig": {
    "nodeType": "DASHBOARD",
    "color": "#6366F1",
    "icon": "activity",
    "entityLabel": "Dashboard",
    "relationships": []
  },
  "type": "ANALYTICS",
  "slug": "analytics",
  "agentType": "analyst",
  "pricing": {
    "type": "subscription",
    "monthlyPriceCents": 1000
  },
  "author": {
    "name": "SpokeStack",
    "url": "https://spokestack.dev"
  }
}
