{
  "id": "crm",
  "moduleType": "CRM",
  "name": "CRM",
  "version": "1.0.0",
  "description": "Full-featured CRM with contact management, deal pipelines, interaction tracking, and AI-powered sales intelligence.",
  "category": "core",
  "minTier": "STARTER",
  "agentDefinition": {
    "path": "src/agent/crm-agent.ts",
    "name": "crm-agent"
  },
  "tools": [
    "createContact",
    "listContacts",
    "updateContact",
    "createDeal",
    "updateDeal",
    "listDeals",
    "linkContactToDeal",
    "manageClients",
    "trackClientActivity",
    "handleComplaint",
    "managePipeline",
    "logInteraction",
    "searchCRM",
    "exportContacts",
    "manageDealContacts",
    "manageDealProducts",
    "trackDealCompetitors",
    "getDealStageHistory",
    "manageContactNotes",
    "manageContactActivities",
    "manageCRMTasks",
    "manageProducts",
    "manageCompetitors",
    "manageCRMCampaigns",
    "manageRetainerPeriods"
  ],
  "surfaces": [
    {
      "id": "crm-dashboard",
      "type": "dashboard",
      "requiredTools": ["listDeals", "listContacts"]
    },
    {
      "id": "crm-overview",
      "type": "full-page",
      "route": "/crm",
      "requiredTools": ["listContacts", "listDeals"]
    },
    {
      "id": "crm-contacts",
      "type": "full-page",
      "route": "/crm/contacts",
      "requiredTools": ["listContacts", "createContact", "updateContact"]
    },
    {
      "id": "crm-deals",
      "type": "full-page",
      "route": "/crm/deals",
      "requiredTools": ["listDeals", "createDeal", "updateDeal", "linkContactToDeal"]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  }
}
