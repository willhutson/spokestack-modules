{
  "id": "crm",
  "moduleType": "CRM",
  "name": "CRM",
  "version": "1.0.0",
  "description": "Full-featured CRM with contact management, deal pipelines, interaction tracking, and AI-powered sales intelligence.",
  "category": "core",
  "minTier": "STARTER",
  "agentDefinition": {
    "path": "src/agent/crm-agent.ts",
    "name": "crm-agent"
  },
  "tools": [
    {
      "name": "create_client",
      "description": "Create a new client",
      "method": "POST",
      "path": "/api/v1/clients",
      "parameters": {
        "name": {
          "type": "string",
          "required": true
        },
        "email": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        }
      }
    },
    {
      "name": "update_client",
      "description": "Update client information",
      "method": "PATCH",
      "path": "/api/v1/clients/{clientId}",
      "parameters": {
        "clientId": {
          "type": "string",
          "required": true,
          "in": "path"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "company": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        }
      }
    },
    {
      "name": "list_clients",
      "description": "List all clients in the workspace",
      "method": "GET",
      "path": "/api/v1/clients",
      "parameters": {}
    },
    {
      "name": "list_orders",
      "description": "List all orders",
      "method": "GET",
      "path": "/api/v1/orders",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_briefs",
      "description": "List all briefs, optionally filtered by status",
      "method": "GET",
      "path": "/api/v1/briefs",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "read_context",
      "description": "Read organizational context — team patterns, client info, preferences, insights",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "category": {
          "type": "string",
          "in": "query"
        },
        "entryType": {
          "type": "string",
          "in": "query",
          "enum": [
            "ENTITY",
            "PATTERN",
            "PREFERENCE",
            "INSIGHT"
          ]
        }
      }
    },
    {
      "name": "write_context",
      "description": "Write a new insight, pattern, or entity to the organizational context graph",
      "method": "POST",
      "path": "/api/v1/context",
      "parameters": {
        "entryType": {
          "type": "string",
          "required": true,
          "enum": [
            "ENTITY",
            "PATTERN",
            "PREFERENCE",
            "INSIGHT"
          ]
        },
        "category": {
          "type": "string",
          "required": true
        },
        "key": {
          "type": "string",
          "required": true
        },
        "value": {
          "type": "object",
          "required": true
        },
        "confidence": {
          "type": "number"
        }
      }
    }
  ],
  "surfaces": [
    {
      "id": "crm-dashboard",
      "type": "dashboard",
      "requiredTools": [
        "listDeals",
        "listContacts"
      ]
    },
    {
      "id": "crm-overview",
      "type": "full-page",
      "route": "/crm",
      "requiredTools": [
        "listContacts",
        "listDeals"
      ]
    },
    {
      "id": "crm-contacts",
      "type": "full-page",
      "route": "/crm/contacts",
      "requiredTools": [
        "listContacts",
        "createContact",
        "updateContact"
      ]
    },
    {
      "id": "crm-deals",
      "type": "full-page",
      "route": "/crm/deals",
      "requiredTools": [
        "listDeals",
        "createDeal",
        "updateDeal",
        "linkContactToDeal"
      ]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  },
  "contextSchema": {
    "categoryPrefix": "crm",
    "entityTypes": [
      {
        "category": "crm.contact",
        "keyFormat": "{contactId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "company": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "lastInteractionAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "name"
          ]
        },
        "relatedCategories": [
          "crm.deal"
        ]
      },
      {
        "category": "crm.deal",
        "keyFormat": "{dealId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "value": {
              "type": "number"
            },
            "stage": {
              "type": "string",
              "enum": [
                "prospect",
                "proposal",
                "negotiation",
                "closed_won",
                "closed_lost"
              ]
            },
            "contactId": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "stage"
          ]
        },
        "relatedCategories": [
          "crm.contact"
        ]
      }
    ],
    "patternTypes": [
      "deal_velocity",
      "contact_frequency",
      "pipeline_stall"
    ]
  },
  "canvasConfig": {
    "nodeType": "DEAL",
    "color": "#10B981",
    "icon": "handshake",
    "entityLabel": "Deal",
    "relationships": [
      {
        "sourceField": "contactId",
        "targetModule": "CRM",
        "targetEntity": "contact",
        "label": "contact",
        "edgeStyle": "solid"
      },
      {
        "sourceField": "projectId",
        "targetModule": "PROJECTS",
        "targetEntity": "project",
        "label": "linked to",
        "edgeStyle": "dashed"
      }
    ]
  },
  "type": "CRM",
  "slug": "crm",
  "agentType": "crm_manager",
  "pricing": {
    "type": "subscription",
    "monthlyPriceCents": 1000
  },
  "author": {
    "name": "SpokeStack",
    "url": "https://spokestack.dev"
  },
  "contextCategories": [
    "contact",
    "deal",
    "company"
  ]
}
