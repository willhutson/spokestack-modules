{
  "id": "crm",
  "moduleType": "CRM",
  "name": "CRM",
  "version": "1.0.0",
  "description": "Full-featured CRM with contact management, deal pipelines, interaction tracking, and AI-powered sales intelligence.",
  "category": "core",
  "minTier": "STARTER",
  "agentDefinition": {
    "path": "src/agent/crm-agent.ts",
    "name": "crm-agent"
  },
  "tools": [
    "createContact",
    "listContacts",
    "updateContact",
    "createDeal",
    "updateDeal",
    "listDeals",
    "linkContactToDeal",
    "managePipeline",
    "logInteraction",
    "searchCRM",
    "exportContacts",
    "manageDealContacts",
    "manageDealProducts",
    "trackDealCompetitors",
    "getDealStageHistory",
    "manageContactNotes",
    "manageContactActivities",
    "manageCRMTasks",
    "manageProducts",
    "manageCompetitors",
    "manageCRMCampaigns",
    "handleComplaint",
    "listComplaints",
    "getComplaintDetails"
  ],
  "surfaces": [
    {
      "id": "crm-dashboard",
      "type": "dashboard",
      "requiredTools": [
        "listDeals",
        "listContacts"
      ]
    },
    {
      "id": "crm-overview",
      "type": "full-page",
      "route": "/crm",
      "requiredTools": [
        "listContacts",
        "listDeals"
      ]
    },
    {
      "id": "crm-contacts",
      "type": "full-page",
      "route": "/crm/contacts",
      "requiredTools": [
        "listContacts",
        "createContact",
        "updateContact"
      ]
    },
    {
      "id": "crm-deals",
      "type": "full-page",
      "route": "/crm/deals",
      "requiredTools": [
        "listDeals",
        "createDeal",
        "updateDeal",
        "linkContactToDeal"
      ]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  },
  "contextSchema": {
    "categoryPrefix": "crm",
    "entityTypes": [
      {
        "category": "crm.contact",
        "keyFormat": "{contactId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "company": {
              "type": "string"
            },
            "email": {
              "type": "string"
            },
            "lastInteractionAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "name"
          ]
        },
        "relatedCategories": [
          "crm.deal"
        ]
      },
      {
        "category": "crm.deal",
        "keyFormat": "{dealId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "title": {
              "type": "string"
            },
            "value": {
              "type": "number"
            },
            "stage": {
              "type": "string",
              "enum": [
                "prospect",
                "proposal",
                "negotiation",
                "closed_won",
                "closed_lost"
              ]
            },
            "contactId": {
              "type": "string"
            }
          },
          "required": [
            "title",
            "stage"
          ]
        },
        "relatedCategories": [
          "crm.contact"
        ]
      }
    ],
    "patternTypes": [
      "deal_velocity",
      "contact_frequency",
      "pipeline_stall"
    ]
  },
  "canvasConfig": {
    "nodeType": "DEAL",
    "color": "#10B981",
    "icon": "handshake",
    "entityLabel": "Deal",
    "relationships": [
      {
        "sourceField": "contactId",
        "targetModule": "CRM",
        "targetEntity": "contact",
        "label": "contact",
        "edgeStyle": "solid"
      },
      {
        "sourceField": "projectId",
        "targetModule": "PROJECTS",
        "targetEntity": "project",
        "label": "linked to",
        "edgeStyle": "dashed"
      }
    ]
  },
  "type": "CRM",
  "slug": "crm",
  "agentType": "crm_manager",
  "pricing": {
    "type": "subscription",
    "monthlyPriceCents": 1000
  },
  "author": {
    "name": "SpokeStack",
    "url": "https://spokestack.dev"
  }
}
