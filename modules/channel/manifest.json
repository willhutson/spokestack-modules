{
  "id": "channel",
  "moduleType": "CHANNEL",
  "name": "Channel",
  "version": "1.0.0",
  "description": "Omnichannel orchestration across Slack, email, WhatsApp, SMS, and Teams with automated flows.",
  "category": "marketing",
  "minTier": "PRO",
  "price": 2900,
  "agentDefinition": {
    "path": "src/agent/channel-agent.ts",
    "name": "channel-agent"
  },
  "tools": [
    {
      "name": "list_tasks",
      "description": "List tasks with optional status filter",
      "method": "GET",
      "path": "/api/v1/tasks",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        },
        "assigneeId": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_projects",
      "description": "List all projects, optionally filtered by status",
      "method": "GET",
      "path": "/api/v1/projects",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_briefs",
      "description": "List all briefs, optionally filtered by status",
      "method": "GET",
      "path": "/api/v1/briefs",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_orders",
      "description": "List all orders",
      "method": "GET",
      "path": "/api/v1/orders",
      "parameters": {
        "status": {
          "type": "string",
          "in": "query"
        }
      }
    },
    {
      "name": "list_clients",
      "description": "List all clients in the workspace",
      "method": "GET",
      "path": "/api/v1/clients",
      "parameters": {}
    },
    {
      "name": "create_task",
      "description": "Create a new task in the workspace",
      "method": "POST",
      "path": "/api/v1/tasks",
      "parameters": {
        "title": {
          "type": "string",
          "required": true,
          "description": "Task title"
        },
        "description": {
          "type": "string",
          "description": "Task description"
        },
        "priority": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "URGENT"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "TODO",
            "IN_PROGRESS",
            "DONE"
          ]
        },
        "assigneeId": {
          "type": "string",
          "description": "User ID to assign to"
        },
        "dueDate": {
          "type": "string",
          "description": "Due date in ISO format"
        }
      }
    },
    {
      "name": "update_task",
      "description": "Update a task's status, priority, assignee, or other fields",
      "method": "PATCH",
      "path": "/api/v1/tasks/{taskId}",
      "parameters": {
        "taskId": {
          "type": "string",
          "required": true,
          "in": "path"
        },
        "status": {
          "type": "string",
          "enum": [
            "TODO",
            "IN_PROGRESS",
            "DONE"
          ]
        },
        "priority": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH",
            "URGENT"
          ]
        },
        "title": {
          "type": "string"
        },
        "assigneeId": {
          "type": "string"
        }
      }
    },
    {
      "name": "complete_task",
      "description": "Mark a task as done",
      "method": "PATCH",
      "path": "/api/v1/tasks/{taskId}",
      "parameters": {
        "taskId": {
          "type": "string",
          "required": true,
          "in": "path"
        }
      },
      "fixedBody": {
        "status": "DONE"
      }
    },
    {
      "name": "read_context",
      "description": "Read organizational context — team patterns, client info, preferences, insights",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "category": {
          "type": "string",
          "in": "query"
        },
        "entryType": {
          "type": "string",
          "in": "query",
          "enum": [
            "ENTITY",
            "PATTERN",
            "PREFERENCE",
            "INSIGHT"
          ]
        }
      }
    },
    {
      "name": "get_recent_activity",
      "description": "Get recent activity across all entities in the workspace",
      "method": "GET",
      "path": "/api/v1/activity",
      "parameters": {
        "limit": {
          "type": "integer",
          "in": "query",
          "default": 20
        }
      }
    },
    {
      "name": "list_team_members",
      "description": "List all team members in the workspace",
      "method": "GET",
      "path": "/api/v1/team",
      "parameters": {}
    },
    {
      "name": "search_workspace",
      "description": "Search across tasks, projects, briefs, clients, and orders via context graph",
      "method": "GET",
      "path": "/api/v1/context",
      "parameters": {
        "search": {
          "type": "string",
          "required": true,
          "in": "query",
          "description": "Search query"
        }
      }
    }
  ],
  "surfaces": [
    {
      "id": "channel-dashboard",
      "type": "dashboard",
      "requiredTools": [
        "listChannels",
        "sendMessage"
      ]
    },
    {
      "id": "channel-overview",
      "type": "full-page",
      "route": "/channel",
      "requiredTools": [
        "listChannels",
        "sendMessage"
      ]
    }
  ],
  "migrations": {
    "install": "migrations/install.ts",
    "uninstall": "migrations/uninstall.ts"
  },
  "contextSchema": {
    "categoryPrefix": "channel",
    "entityTypes": [
      {
        "category": "channel.record",
        "keyFormat": "{recordId}",
        "valueSchema": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "status": {
              "type": "string"
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            }
          },
          "required": [
            "name"
          ]
        },
        "relatedCategories": []
      }
    ],
    "patternTypes": [
      "channel_activity",
      "channel_trend"
    ]
  },
  "type": "CHANNEL",
  "slug": "channel",
  "agentType": "assistant",
  "pricing": {
    "type": "subscription",
    "monthlyPriceCents": 1000
  },
  "author": {
    "name": "SpokeStack",
    "url": "https://spokestack.dev"
  }
}
