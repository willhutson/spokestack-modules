{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "paths": {
      "@spokestack/sdk": ["./sdk/index.ts"],
      "@spokestack/sdk/*": ["./sdk/*"],
      "@spokestack/module-sdk": ["./sdk/index.ts"],
      "@spokestack/module-sdk/*": ["./sdk/*"],
      "@spokestack/core-schema": ["./core-schema/index.ts"],
      "@spokestack/marketplace": ["./marketplace/index.ts"]
    }
  },
  "include": [
    "sdk/**/*.ts",
    "marketplace/**/*.ts",
    "modules/**/src/**/*.ts",
    "modules/**/tests/**/*.ts",
    "modules/**/manifest.json",
    "modules/**/migrations/**/*.ts",
    "modules/**/agent/**/*.ts",
    "core-schema/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.tsx"
  ]
}
